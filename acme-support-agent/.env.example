# Copy to .env and fill in. Used by the Python agent and verify scripts.

# --- where telemetry goes (local stack defaults) ---
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=acme-support-agent

# --- OpenSearch (LOCAL DEV ONLY — never use these in production) ---
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=My_password_123!@#

# --- which framework + model the agent runs ---
ACME_FRAMEWORK=openai
ACME_MODEL=gpt-4o

# --- provider credentials (set the one you use) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Bedrock uses standard AWS credentials:
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
